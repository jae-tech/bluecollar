{
  "name": "bluecollar",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "verify:env": "node ./scripts/verify-env.js",
    "dev:init": "pnpm build && docker-compose up -d && node ./scripts/wait-for-db.js && pnpm --filter @repo/database db:push && pnpm --filter @repo/database db:seed",
    "db:down": "docker-compose down",
    "db:status": "docker-compose ps"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.8.1",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@nestjs/throttler": "^6.5.0",
    "@opennextjs/cloudflare": "^1.18.0",
    "@types/nodemailer": "^7.0.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-kakao": "^1.0.3",
    "handlebars": "^4.7.8",
    "nodemailer": "^8.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-kakao": "^1.0.1",
    "wrangler": "^4.78.0"
  }
}
