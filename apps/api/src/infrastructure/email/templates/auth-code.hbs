<!-- 제목 영역 -->
<h2
  style='margin: 0 0 8px; font-size: 22px; font-weight: 700; color: #1C1917; letter-spacing: -0.4px; line-height: 1.3;'
>{{title}}</h2>
<p
  style='margin: 0 0 32px; font-size: 15px; color: #6B5E57; line-height: 1.6; font-weight: 400;'
>{{message}}</p>

<!-- 인증코드 박스 -->
<table
  border='0'
  cellpadding='0'
  cellspacing='0'
  width='100%'
  style='margin-bottom: 32px;'
>
  <tr>
    <td
      align='center'
      style='background-color: #F5F0EB; border-radius: 8px; padding: 32px 24px;'
    >
      <div
        style='font-size: 11px; font-weight: 600; color: #6B5E57; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 16px;'
      >인증번호</div>
      <div
        style='font-size: 44px; font-weight: 700; color: #292524; letter-spacing: 8px; font-family: Courier New, Courier, monospace; line-height: 1;'
      >{{authCode}}</div>
      <div
        style='font-size: 12px; color: #6B5E57; margin-top: 16px; line-height: 1.5;'
      >위 번호를 인증 화면에 입력해주세요.</div>
    </td>
  </tr>
</table>

<!-- 유효시간 안내 -->
<table border='0' cellpadding='0' cellspacing='0' width='100%' style='margin-bottom: 32px;'>
  <tr>
    <td
      style='background-color: #FFFBEB; border-radius: 6px; padding: 14px 16px;'
    >
      <table border='0' cellpadding='0' cellspacing='0' width='100%'>
        <tr>
          <td valign='top' width='20' style='padding-right: 10px;'>
            <span style='font-size: 14px;'>⏱</span>
          </td>
          <td>
            <div
              style='font-size: 13px; font-weight: 600; color: #D97706; margin-bottom: 4px;'
            >유효시간 안내</div>
            <p style='margin: 0; font-size: 12px; color: #92400E; line-height: 1.5;'>
              이 인증번호는 <strong>24시간</strong> 동안 유효합니다.<br />
              본인이 요청하지 않은 이메일이라면 무시하셔도 됩니다.
            </p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<!-- 보안 안내 -->
<p
  style='margin: 0; font-size: 12px; color: #B8AFA9; line-height: 1.6; border-top: 1px solid #E5E0DB; padding-top: 20px;'
>
  BlueCollar는 이메일·전화로 인증번호를 요청하지 않습니다.
  의심스러운 요청을 받으셨다면
  <a href='mailto:support@bluecollar.cv' style='color: #292524;'>support@bluecollar.cv</a>로 알려주세요.
</p>
