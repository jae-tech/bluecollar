NODE_ENV=development

# ── 데이터베이스 ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/bluecollar_dev"

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=                        # 32자 이상 랜덤 문자열 필수
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── 이메일 ───────────────────────────────────────────────────
EMAIL_SERVICE=mock                 # mock | nodemailer
EMAIL_HOST=smtp.zoho.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_REPLY_TO=

# ── 개발용 인증 코드 노출 (staging/dev 전용) ──────────────────
EXPOSE_EMAIL_CODE=false
EXPOSE_SMS_CODE=false

# ── SMS ──────────────────────────────────────────────────────
SMS_PROVIDER=mock                  # mock | coolsms | twilio
# COOLSMS_FROM_NUMBER=
# TWILIO_PHONE_NUMBER=

# ── Google OAuth (선택 — 미설정 시 해당 전략 비활성화) ─────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/callback/google

# ── Kakao OAuth (선택 — 미설정 시 해당 전략 비활성화) ──────────
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL=http://localhost:4000/auth/callback/kakao

# ── 파일 업로드 ──────────────────────────────────────────────
STORAGE_PATH=./uploads
MEDIA_BASE_URL=http://localhost:4000

# ── URL ──────────────────────────────────────────────────────
API_URL=http://localhost:4000
APP_URL=http://localhost:3000

# ── Slack 알림 (선택) ─────────────────────────────────────────
# SLACK_WEBHOOK_URL=
