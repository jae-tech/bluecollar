# BlueCollar API - Environment Variables
# Copy this file to .env and update values as needed

# Database Connection
DATABASE_URL="postgresql://bluecollar_user:bluecollar_password@localhost:5432/bluecollar_dev"

# API Configuration
NODE_ENV=development
PORT=4000

# JWT Configuration (optional, for future use)
JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=7d

# CORS Configuration
ALLOWED_ORIGINS=localhost:3000,localhost:3001

# Slack Webhook (Optional - for critical error notifications)
# Set SLACK_WEBHOOK_URL to receive alerts for 500+ errors
# Format: https://hooks.slack.com/services/YOUR_TEAM_ID/YOUR_BOT_ID/YOUR_TOKEN
SLACK_WEBHOOK_URL=
